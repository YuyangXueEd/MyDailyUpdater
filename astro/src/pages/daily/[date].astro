---
import Base from '@/layouts/Base.astro';
import SectionBlock from '@/components/SectionBlock.astro';
import { readdir, readFile } from 'node:fs/promises';
import { resolve } from 'node:path';

declare const __DATA_ROOT__: string;
const DATA_DIR = resolve(__DATA_ROOT__, 'daily');

export async function getStaticPaths() {
  const dir = resolve(__DATA_ROOT__, 'daily');
  const files = await readdir(dir);
  return files
    .filter((f: string) => /^\d{4}-\d{2}-\d{2}\.json$/.test(f))
    .map((f: string) => ({ params: { date: f.replace('.json', '') } }));
}

const { date } = Astro.params;
// eslint-disable-next-line @typescript-eslint/no-explicit-any
const data: any = JSON.parse(await readFile(resolve(DATA_DIR, `${date}.json`), 'utf-8'));

interface Section {
  key: string;
  payload_key?: string;
  title: string;
  icon?: string;
  items: Record<string, unknown>[];
  meta?: Record<string, unknown>;
}

const sections: Section[] = data.sections_ordered ?? [];
const meta: Record<string, unknown> = data.meta ?? {};
const generatedAt: string = String(data.generated_at ?? '').slice(0, 10);

const totalItems = sections.reduce((n, s) => n + (s.items?.length ?? 0), 0);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const allFiles = await readdir(DATA_DIR);
const allDates = allFiles
  .filter((f: string) => /^\d{4}-\d{2}-\d{2}\.json$/.test(f))
  .map((f: string) => f.replace('.json', ''))
  .sort();
const idx = allDates.indexOf(date as string);
const prevDate = idx > 0 ? allDates[idx - 1] : null;
const nextDate = idx < allDates.length - 1 ? allDates[idx + 1] : null;
---
<Base title={`${date} Daily Digest`} description={`Linnet daily research digest for ${date}`}>
  <div class="page-wrap">
    <header class="digest-hero panel" style="margin-top:1.5rem;padding:1.5rem;">
      <div class="kicker">Daily issue</div>
      <h1 style="font-size:clamp(1.6rem,3vw,2.4rem);font-weight:800;letter-spacing:-0.03em;line-height:1.1;margin-bottom:.5rem;">
        {date}
      </h1>
      <p style="color:var(--site-text-muted);font-size:.9rem;">
        {generatedAt && `Generated ${generatedAt}`}
        {meta.llm_model && ` · ${String(meta.llm_model)}`}
      </p>
      <div style="display:flex;gap:.5rem;flex-wrap:wrap;margin-top:1rem;">
        <span class="chip chip--accent">{totalItems} items</span>
        <span class="chip">{sections.length} sources</span>
      </div>
    </header>

    <details class="section-nav-mobile panel" style="margin-top:1rem;padding:.75rem 1rem;">
      <summary style="cursor:pointer;font-family:'JetBrains Mono',monospace;font-size:.72rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--site-brand);">
        Jump to section
      </summary>
      <ul style="margin:.5rem 0 0 .75rem;padding:0;list-style:none;">
        {sections.filter(s => s.items?.length).map(s => (
          <li style="margin:.2rem 0;">
            <a href={`#${s.key.toLowerCase().replace(/[^a-z0-9]+/g,'-')}`}
               style="color:var(--site-text-muted);font-size:.85rem;text-decoration:none;">
              {s.icon} {s.title}
            </a>
          </li>
        ))}
      </ul>
    </details>

    <div class="digest-body" style="margin-top:1.5rem;">
      {sections.map(section => (
        <SectionBlock section={section} />
      ))}
    </div>

    <nav class="digest-nav panel" style="display:flex;justify-content:space-between;align-items:center;padding:1rem 1.25rem;margin:2rem 0 3rem;">
      {prevDate ? (
        <a href={`${base}/daily/${prevDate}/`} class="btn btn--secondary">← {prevDate}</a>
      ) : <span />}
      <a href={`${base}/daily/`} class="btn btn--secondary">Archive</a>
      {nextDate ? (
        <a href={`${base}/daily/${nextDate}/`} class="btn btn--secondary">{nextDate} →</a>
      ) : <span />}
    </nav>
  </div>

  <aside class="section-nav-desktop panel" aria-label="Page sections">
    <p class="kicker" style="margin-bottom:.5rem;">Sections</p>
    <ul>
      {sections.filter(s => s.items?.length).map(s => (
        <li>
          <a href={`#${s.key.toLowerCase().replace(/[^a-z0-9]+/g,'-')}`}>
            {s.icon} {s.title}
          </a>
        </li>
      ))}
    </ul>
  </aside>
</Base>

<style>
.section-nav-desktop {
  position: fixed;
  right: 1.25rem;
  top: calc(var(--nav-height) + 1.5rem);
  width: 190px;
  padding: .9rem 1rem;
  font-size: .78rem;
  max-height: calc(100vh - var(--nav-height) - 3rem);
  overflow-y: auto;
  scrollbar-width: thin;
  z-index: 30;
}
.section-nav-desktop ul { list-style: none; margin: 0; padding: 0; }
.section-nav-desktop li { margin: .2rem 0; }
.section-nav-desktop a { color: var(--site-text-muted); text-decoration: none; display: block; padding: .15rem 0; }
.section-nav-desktop a:hover { color: var(--site-brand); }
.section-nav-mobile { display: none; }

@media (max-width: 1140px) {
  .section-nav-desktop { display: none; }
  .section-nav-mobile { display: block; }
}
</style>
