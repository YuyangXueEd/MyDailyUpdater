---
import NavBar from '@/components/NavBar.astro';
import '@/styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = 'Daily AI/CV/Medical Imaging research updates — auto-generated at UK midnight', ogImage } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
  <meta name="generator" content={Astro.generator} />
  <title>{title} — Linnet</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <!-- OG -->
  <meta property="og:title" content={`${title} — Linnet`} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  {ogImage && <meta property="og:image" content={ogImage} />}
  <!-- Theme init: prevent flash -->
  <script is:inline>
    const t = localStorage.getItem('theme') ||
      (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
    document.documentElement.dataset.theme = t;
  </script>
</head>
<body>
  <NavBar />
  <main>
    <slot />
  </main>
  <footer class="site-footer">
    <div class="page-wrap">
      <p>Auto-generated by <a href="https://github.com/YuyangXueEd/linnet">Linnet</a> · <a href={`${import.meta.env.BASE_URL}support/`}>Support the project</a></p>
    </div>
  </footer>
</body>
</html>

<style>
.site-footer {
  margin-top: 4rem;
  padding: 1.5rem 0;
  border-top: 1px solid var(--site-border);
  text-align: center;
  font-size: 0.82rem;
  color: var(--site-text-muted);
}
</style>
