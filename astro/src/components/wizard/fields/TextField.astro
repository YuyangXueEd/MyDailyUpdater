---
import type { SetupField } from '@/lib/registry';

interface Props {
  field: SetupField;
  extKey: string;
  locale: 'en' | 'zh';
}
const { field, extKey, locale } = Astro.props;
const label = locale === 'zh' ? (field.labelZh ?? field.label) : field.label;
const hint  = locale === 'zh' ? (field.hintZh  ?? field.hint)  : field.hint;
const id = `${extKey}-${field.key}`;
const inputType = field.type === 'number' ? 'number' : 'text';
const defaultValue = field.default as string | number | undefined;
---
<div class="wz-field wz-field--compact">
  <label for={id}>{label}</label>
  <input
    type={inputType}
    id={id}
    name={field.key}
    placeholder={field.placeholder ?? ''}
    value={defaultValue}
    min={field.min}
    max={field.max}
    step={field.step}
    required={field.required}
    data-config-for={extKey}
    data-field={field.key}
  />
  {hint && <div class="wz-field__hint">{hint}</div>}
</div>
