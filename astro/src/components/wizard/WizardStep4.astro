---
interface Props {
  locale: 'en' | 'zh';
}
const { locale } = Astro.props;

const t = {
  desc:           locale === 'zh' ? '在不将密钥写入 YAML 的情况下启用通知。凭据作为 GitHub Actions Secret 单独存储。' : 'Enable notifications without pasting secrets into YAML. Credentials are stored as GitHub Actions secrets separately.',
  slackHead:      'Slack',
  slackEnable:    locale === 'zh' ? '启用 Slack 推送' : 'Enable Slack delivery',
  webhookHint:    locale === 'zh' ? '稍后作为 SLACK_WEBHOOK_URL 添加为 GitHub Actions Secret。' : 'Add as SLACK_WEBHOOK_URL GitHub Actions secret — not stored in YAML.',
  maxPapers:      locale === 'zh' ? '最多论文数' : 'Max papers',
  maxHn:          locale === 'zh' ? '最多 HN 条目' : 'Max HN stories',
  maxGithub:      locale === 'zh' ? '最多 GitHub 仓库' : 'Max GitHub repos',
  scHead:         locale === 'zh' ? 'Server酱 (ServerChan)' : 'Server酱 (ServerChan)',
  scEnable:       locale === 'zh' ? '启用 Server酱推送' : 'Enable ServerChan delivery',
  scHint:         locale === 'zh' ? '稍后作为 SERVERCHAN_SENDKEY 添加为 GitHub Actions Secret。' : 'Add as SERVERCHAN_SENDKEY GitHub Actions secret — not stored in YAML.',
  maxJobs:        locale === 'zh' ? '最多职位数' : 'Max jobs',
};
---

<div class="wz-step" data-step="4" aria-hidden="true">
  <p class="wz-step__desc">{t.desc}</p>

  <div class="wz-stack">

    <!-- Slack -->
    <div class="wz-card">
      <div class="wz-card__header">
        <h3>{t.slackHead}</h3>
        <label class="wz-toggle">
          <input type="checkbox" id="slack-enabled" data-sink-slack-enabled />
          <span class="wz-toggle__label">{t.slackEnable}</span>
        </label>
      </div>
      <div class="wz-sink-fields" data-sink-slack-fields>
        <div class="wz-notice wz-notice--info">{t.webhookHint}</div>
        <div class="wz-field-row">
          <div class="wz-field">
            <label for="slack-max-papers">{t.maxPapers}</label>
            <input type="number" id="slack-max-papers" data-sink-slack-max-papers min="1" max="20" value="5" />
          </div>
          <div class="wz-field">
            <label for="slack-max-hn">{t.maxHn}</label>
            <input type="number" id="slack-max-hn" data-sink-slack-max-hn min="1" max="15" value="3" />
          </div>
          <div class="wz-field">
            <label for="slack-max-github">{t.maxGithub}</label>
            <input type="number" id="slack-max-github" data-sink-slack-max-github min="1" max="15" value="3" />
          </div>
        </div>
      </div>
    </div>

    <!-- ServerChan -->
    <div class="wz-card">
      <div class="wz-card__header">
        <h3>{t.scHead}</h3>
        <label class="wz-toggle">
          <input type="checkbox" id="sc-enabled" data-sink-sc-enabled />
          <span class="wz-toggle__label">{t.scEnable}</span>
        </label>
      </div>
      <div class="wz-sink-fields" data-sink-sc-fields>
        <div class="wz-notice wz-notice--info">{t.scHint}</div>
        <div class="wz-field-row">
          <div class="wz-field">
            <label for="sc-max-papers">{t.maxPapers}</label>
            <input type="number" id="sc-max-papers" data-sink-sc-max-papers min="1" max="20" value="5" />
          </div>
          <div class="wz-field">
            <label for="sc-max-hn">{t.maxHn}</label>
            <input type="number" id="sc-max-hn" data-sink-sc-max-hn min="1" max="15" value="3" />
          </div>
          <div class="wz-field">
            <label for="sc-max-github">{t.maxGithub}</label>
            <input type="number" id="sc-max-github" data-sink-sc-max-github min="1" max="15" value="3" />
          </div>
          <div class="wz-field">
            <label for="sc-max-jobs">{t.maxJobs}</label>
            <input type="number" id="sc-max-jobs" data-sink-sc-max-jobs min="1" max="10" value="3" />
          </div>
        </div>
      </div>
    </div>

  </div>
</div>
