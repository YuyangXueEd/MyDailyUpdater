{% if sec["items"] %}
<ul>
  {% set nav_ns = namespace(seen=[]) %}
  {% for p in sec["items"] %}
    {% set category_name = p.get('primary_category', (p.categories[0] if p.categories else 'Other')) %}
    {% set category_anchor = p.get('primary_category_anchor', category_name | lower | replace('.', '-') | replace(' ', '-') | replace('/', '-')) %}
    {% if category_anchor not in nav_ns.seen %}
    <li><a href="#cat-{{ category_anchor }}">{{ category_name }}</a></li>
    {% set _ = nav_ns.seen.append(category_anchor) %}
    {% endif %}
  {% endfor %}
</ul>
{% endif %}
