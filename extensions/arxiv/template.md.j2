<h2 id="arxiv">{{ sec.icon }} {{ sec.title }} Today ({{ sec["items"]|length }})</h2>

{% if sec["items"] %}
{% set content_ns = namespace(seen=[]) %}
{% for p in sec["items"] %}
{% set category_name = p.get('primary_category', (p.categories[0] if p.categories else 'Other')) %}
{% set category_anchor = p.get('primary_category_anchor', category_name | lower | replace('.', '-') | replace(' ', '-') | replace('/', '-')) %}
{% if category_anchor not in content_ns.seen %}
<h3 id="cat-{{ category_anchor }}">{{ category_name }}</h3>
{% set _ = content_ns.seen.append(category_anchor) %}
{% endif %}

<h4>{{ loop.index }}. <a href="{{ p.url }}">{{ p.title }}</a></h4>

**Authors:** {{ p.authors | join(', ') }}{% if p.affiliations %} | **Affiliations:** {{ p.affiliations | join('; ') }}{% endif %} | **Categories:** {{ p.categories | join(', ') }}{% if p.score is defined and p.score %} | **Score:** {{ "%.1f"|format(p.score) }}/10{% endif %}

{% if p.figure_url %}
![{{ p.figure_caption or p.title }}]({{ p.figure_url }})
{% if p.figure_caption %}
*Figure 1.* {{ p.figure_caption }}
{% endif %}
{% endif %}

{{ p.abstract }}

---
{% endfor %}
{% else %}
{% if meta.get('papers_after_keyword_filter', 0) > 0 %}
*No papers made the final cut today. {{ meta.papers_after_keyword_filter }} candidates passed keyword filtering but scored 0 after LLM scoring — this usually means the scoring threshold is too strict or the scoring request failed.*
{% else %}
*No papers matched today's filters.*
{% endif %}
{% endif %}
