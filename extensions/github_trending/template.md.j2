{% if sec["items"] %}
<h2 id="github_trending">{{ sec.icon }} {{ sec.title }} ({{ sec["items"]|length }})</h2>

{% for r in sec["items"] %}
- **[{{ r.full_name }}]({{ r.url }})** {% if r.language %}· {{ r.language }}{% endif %} {% if r.stars_today %}· ⭐ +{{ r.stars_today }} today{% elif r.total_stars %}· ⭐ {{ r.total_stars }}{% endif %}

  {{ r.description | replace('\n', ' ') | truncate(100, True, '…') }}{% if r.summary %}
  > {{ r.summary }}{% endif %}

{% endfor %}
{% endif %}
