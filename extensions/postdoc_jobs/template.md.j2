{% if sec["items"] %}
<h2 id="postdoc_jobs">{{ sec.icon }} {{ sec.title }} ({{ sec["items"]|length }})</h2>

{% for j in sec["items"] %}
### [{{ j.title }}]({{ j.url }})

**Institution:** {{ j.institution or 'Unknown' }} | **Location:** {{ j.location or 'N/A' }} | **Source:** {{ j.source }} | **Deadline:** {{ j.deadline or 'N/A' }} | **Relevance:** {{ "%.1f"|format(j.relevance_score) }}/10

{% if j.salary %}
**Salary:** {{ j.salary }}

{% endif %}
{% for line in j.requirements.split('\n') %}{% if line.strip() %}
- {{ line }}
{% endif %}{% endfor %}

---
{% endfor %}
{% endif %}
